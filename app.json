{
  "expo": {
    "name": "Pura",
    "slug": "pura",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logop.png",
    "scheme": "pura",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logop.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web" : {
        "output": "static",
        "favicon": "./assets/logop.png"
       }, 
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/logop.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Pura to access your location for weather."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
